# ═══════════════════════════════════════════════
# CyberGuard Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ═══════════════════════════════════════════════

# ─── App ────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ─── Database ───────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://cyberguard:CHANGE_ME_STRONG_PASSWORD@postgres:5432/cyberguard

# ─── Redis ──────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ─── JWT Security ───────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── HMAC for Custody Chain ─────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CUSTODY_HMAC_KEY=CHANGE_ME_CUSTODY_HMAC_KEY

# ─── CORS ───────────────────────────────────────
ALLOWED_ORIGINS=https://your-domain.com

# ─── Stripe Billing ─────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── LLM (Gemma via Ollama) ─────────────────────
GEMMA_API_URL=http://ollama:11434
GEMMA_MODEL=gemma3:12b
GEMMA_TIMEOUT=120

# ─── S3 Evidence Storage (MinIO) ────────────────
S3_BUCKET=cyberguard-evidence
S3_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
S3_ACCESS_KEY=CHANGE_ME_MINIO_USER
S3_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
S3_REGION=us-east-1

# ─── Threat Intelligence APIs ───────────────────
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# ─── Frontend ───────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com
